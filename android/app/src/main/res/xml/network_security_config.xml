<?xml version="1.0" encoding="utf-8"?>
<!--
  Place this file at:
  android/app/src/main/res/xml/network_security_config.xml

  Then add this attribute to the <application> tag in
  android/app/src/main/AndroidManifest.xml:
    android:networkSecurityConfig="@xml/network_security_config"
-->
<network-security-config>
  <domain-config cleartextTrafficPermitted="false">
    <!-- OneMap API (geocoding) -->
    <domain includeSubdomains="true">onemap.gov.sg</domain>
    <!-- OpenStreetMap (map tiles) -->
    <domain includeSubdomains="true">openstreetmap.org</domain>
    <domain includeSubdomains="true">tile.openstreetmap.org</domain>
    <!-- Google Fonts -->
    <domain includeSubdomains="true">fonts.googleapis.com</domain>
    <domain includeSubdomains="true">fonts.gstatic.com</domain>
    <!-- Leaflet CDN -->
    <domain includeSubdomains="true">unpkg.com</domain>
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </domain-config>
</network-security-config>
